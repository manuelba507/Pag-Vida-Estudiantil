<script>
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const el = document.getElementById('page-' + id);
    if (el) { el.classList.add('active'); window.scrollTo(0, 0); }
  }
 
  function openModal(id) {
    document.getElementById(id).classList.add('open');
    document.body.style.overflow = 'hidden';
  }
 
  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
    document.body.style.overflow = '';
  }
 
  function closeModalOutside(e, id) {
    if (e.target.id === id) closeModal(id);
  }
 
  function submitForm(modalId) {
    closeModal(modalId);
    const toast = document.createElement('div');
    toast.textContent = '✅ ¡Solicitud enviada! Nos pondremos en contacto contigo pronto.';
    toast.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#111827;color:#fff;padding:14px 28px;border-radius:50px;font-size:15px;font-weight:600;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,.2)';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  }
 
  // Caipi carousel
  let caipiSlide = 0;
  function caipiGo(n) {
    caipiSlide = ((n % 3) + 3) % 3;
    document.querySelector('.caipi-slides').style.transform = `translateX(-${caipiSlide * 100}%)`;
    document.querySelectorAll('.caipi-dots span').forEach((d, i) => d.classList.toggle('active', i === caipiSlide));
  }
  setInterval(() => caipiGo(caipiSlide + 1), 4000);

  // Hero slideshow
  let slide = 0;
  const slides = ['img/SaveClip.App_693382464_18348540760212897_1156338101896558044_n.jpg','img/SaveClip.App_669463582_18343116034212897_7268976270134655221_n.jpg','img/SaveClip.App_660295991_18343115854212897_5279633631813186699_n.jpg'];
  setInterval(() => {
    slide = (slide + 1) % slides.length;
    const bg = document.querySelector('.hero-bg');
    if(bg) bg.style.backgroundImage = `linear-gradient(rgba(0,0,0,.45),rgba(0,0,0,.6)),url('${slides[slide]}')`;
    document.querySelectorAll('.hero-dot').forEach((d,i) => d.classList.toggle('active', i===slide));
  }, 4000);
</script>
