<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Proyecto ITSE – Vida Estudiantil</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --primary-blue: #FFD100;
      --yellow: #FFD100;
      --white: #FFFFFF;
      --black: #1A1A1A;
      --gray-light: #F5F5F5;
      --blue-dark: #0B2161;
      --red: #DC2626;
      --red-light: #FEE2E2;
      --gray-50: #F9FAFB;
      --gray-100: #F3F4F6;
      --gray-200: #E5E7EB;
      --gray-500: #6B7280;
      --gray-700: #374151;
      --gray-900: #111827;
      --font-body: 'Inter', sans-serif;
      --font-title: 'Montserrat', sans-serif;
    }
 
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-body); color: var(--black); background: var(--white); font-size: 16px; font-weight: 400; }
 
    h1, h2, h3, h4, h5, h6 { font-family: var(--font-title); font-weight: 700; }
 
    /* ── NAVIGATION ── */
    .page { display: none; }
    .page.active { display: block; }
 
    /* ── INICIO NAV ── */
    .nav-inicio {
      position: absolute; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: center; align-items: center; gap: 48px;
      padding: 20px 40px;
      background: var(--primary-blue);
    }
    .nav-inicio a {
      color: var(--black); text-decoration: none; font-size: 14px; font-weight: 600; letter-spacing: 0.5px;
      cursor: pointer; transition: color .2s;
    }
    .nav-inicio a:hover { color: var(--blue-dark); }
 
    /* ── HERO ── */
    .hero {
      position: relative; height: 100vh; min-height: 600px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background: linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.6)),
                  url('img/SaveClip.App_693382464_18348540760212897_1156338101896558044_n.jpg') center/cover no-repeat;
      filter: grayscale(100%);
    }
    .hero-content {
      position: relative; z-index: 2; text-align: center; color: var(--white);
    }
    .hero-content h1 {
      font-size: clamp(52px, 7vw, 90px); font-weight: 900; line-height: 1.05; font-family: var(--font-title);
    }
    .hero-content h1 span { color: var(--yellow); }
    .hero-content p {
      font-size: clamp(24px, 3.5vw, 42px); font-weight: 700; margin-top: 16px; font-family: var(--font-title);
    }
    .hero-dots {
      position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 8px; z-index: 2;
    }
    .hero-dot {
      width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,.4);
    }
    .hero-dot.active { background: var(--white); }
 
    /* ── SECTION TITLES ── */
    .section { padding: 60px 80px; background: var(--white); }
    .section-sm { padding: 40px 80px; background: var(--white); }
    .section-title {
      font-size: 32px; font-weight: 800; text-align: center; margin-bottom: 8px; font-family: var(--font-title); color: var(--black);
    }
    .section-title strong { color: var(--primary-blue); }
    .section-sub {
      text-align: center; color: var(--gray-500); font-size: 16px; margin-bottom: 40px;
    }
 
    /* ── ACTIVIDADES LABEL ── */
    .actividades-label {
      text-align: center; padding: 40px;
    }
    .actividades-label span {
      font-size: 28px; font-weight: 800; color: var(--yellow); letter-spacing: 1px;
      border: 2px solid var(--yellow); border-radius: 50px; padding: 12px 40px; font-family: var(--font-title);
    }
 
    /* ── BANNER NEGRO ── */
    .banner-black {
      background: var(--blue-dark);
      background-image: url('img/SaveClip.App_642159919_18338080858212897_3074899472525507639_n.jpg');
      background-size: cover; background-position: center;
      position: relative; min-height: 480px;
      display: flex; align-items: center; justify-content: center;
    }
    .banner-black::before {
      content: ''; position: absolute; inset: 0;
      background: rgba(0,0,0,.6); filter: grayscale(100%);
    }
    .banner-black-content {
      position: relative; z-index: 2; text-align: center; color: var(--white);
    }
    .banner-black-content h2 {
      font-size: clamp(36px, 5vw, 64px); font-weight: 900; color: var(--yellow);
      margin-bottom: 12px; font-family: var(--font-title); letter-spacing: 0.5px;
    }
    .banner-black-content p {
      font-size: clamp(28px, 4vw, 52px); font-weight: 800; color: var(--white); font-family: var(--font-title);
    }
 
    /* ── NEWS CARD ── */
    .news-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .news-img-wrap {
      border: 6px solid var(--yellow); border-radius: 12px; overflow: hidden;
    }
    .news-img-wrap img { width: 100%; display: block; }
    .news-text h3 { font-size: 20px; font-weight: 700; margin-bottom: 12px; color: var(--black); font-family: var(--font-title); }
    .news-text p { font-size: 16px; line-height: 1.7; color: var(--gray-700); }
 
    /* ── PHOTO GRID ── */
    .photo-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 40px 80px; background: var(--gray-light);
    }
    .photo-grid img {
      width: 100%; height: 320px; object-fit: cover; border-radius: 12px;
    }
 
    /* ── STANDARD NAV (other pages) ── */
    .std-nav {
      display: flex; align-items: center; gap: 32px;
      padding: 16px 40px; border-bottom: 1px solid var(--gray-200);
      background: var(--white); position: sticky; top: 0; z-index: 100;
    }
    .std-nav .logo { font-size: 16px; font-weight: 800; color: var(--primary-blue); margin-right: auto; font-family: var(--font-title); }
    .std-nav .logo span { font-weight: 400; display: block; font-size: 12px; color: var(--gray-500); }
    .std-nav a {
      font-size: 14px; color: var(--gray-700); text-decoration: none; cursor: pointer;
      transition: color .2s; font-weight: 500;
    }
    .std-nav a:hover { color: var(--primary-blue); }
    .std-nav a.active-link { font-weight: 700; color: var(--primary-blue); }
    .btn { padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 700; letter-spacing: 0.5px; cursor: pointer; border: 2px solid transparent; transition: all .2s; text-decoration: none; display: inline-block; }
    .btn-outline { border-color: var(--gray-300,#d1d5db); color: var(--gray-700); background: transparent; }
    .btn-outline:hover { background: var(--gray-100); }
    .btn-primary { background: var(--primary-blue); color: var(--black); border-color: var(--primary-blue); }
    .btn-primary:hover { background: #e6b800; }
    .btn-green { background: var(--primary-blue); color: var(--black); border-color: var(--primary-blue); border-radius: 50px; }
    .btn-green:hover { background: #e6b800; }
    .btn-white-outline { border-color: var(--black); color: var(--black); background: transparent; border-radius: 50px; }
    .btn-white-outline:hover { background: rgba(0,0,0,.1); }
 
    /* ── HERO CAIPI ── */
    .hero-caipi {
      background: linear-gradient(135deg, #e8f5e9 0%, #f0fdf4 100%);
      padding: 80px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
    }
    .hero-caipi .badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--primary-blue); color: var(--black); border-radius: 50px;
      padding: 6px 16px; font-size: 13px; font-weight: 600; margin-bottom: 20px;
    }
    .hero-caipi h1 { font-size: 44px; font-weight: 900; line-height: 1.1; margin-bottom: 16px; font-family: var(--font-title); }
    .hero-caipi p { font-size: 16px; color: var(--gray-500); margin-bottom: 24px; }
    .info-chips { display: flex; gap: 12px; }
    .chip {
      display: flex; align-items: center; gap: 6px;
      border: 1.5px solid var(--gray-200); border-radius: 50px;
      padding: 6px 16px; font-size: 14px; font-weight: 500; color: var(--gray-700);
    }
    .hero-caipi .img-placeholder {
      background: #93c5fd; border-radius: 16px; height: 380px;
      display: flex; align-items: center; justify-content: center;
      color: var(--white); font-weight: 600; font-size: 18px; overflow: hidden;
    }
    .hero-caipi .img-placeholder img { width: 100%; height: 100%; object-fit: cover; }

    /* ── CAIPI CAROUSEL ── */
    .caipi-carousel { position: relative; border-radius: 16px; overflow: hidden; height: 380px; }
    .caipi-slides { display: flex; height: 100%; transition: transform .45s ease; }
    .caipi-slides img { width: 100%; height: 100%; object-fit: cover; flex-shrink: 0; }
    .caipi-btn {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(0,0,0,.45); color: #fff; border: none;
      width: 40px; height: 40px; border-radius: 50%; font-size: 22px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; z-index: 2;
      transition: background .2s;
    }
    .caipi-btn:hover { background: rgba(0,0,0,.7); }
    .caipi-prev { left: 12px; }
    .caipi-next { right: 12px; }
    .caipi-dots {
      position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 8px; z-index: 2;
    }
    .caipi-dots span {
      width: 9px; height: 9px; border-radius: 50%;
      background: rgba(255,255,255,.5); cursor: pointer; transition: background .2s;
    }
    .caipi-dots span.active { background: #fff; }
 
    /* ── SERVICES CARDS ── */
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .service-card { background: var(--white); border: 1px solid var(--gray-200); border-radius: 16px; padding: 28px; }
    .service-icon {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--primary-blue); display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px; font-size: 24px; color: var(--white);
    }
    .service-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; font-family: var(--font-title); }
    .service-card p { font-size: 14px; color: var(--gray-500); line-height: 1.6; }
 
    /* ── STATS ROW ── */
    .stats-row { display: flex; align-items: center; padding: 40px 80px; gap: 0; }
    .stat-item { flex: 1; text-align: center; }
    .stat-divider { width: 1px; height: 60px; background: var(--gray-200); }
    .stat-num { font-size: 48px; font-weight: 900; font-family: var(--font-title); }
    .stat-label { font-size: 15px; color: var(--gray-500); margin-top: 4px; }
    .orange { color: var(--yellow); }
    .blue { color: var(--primary-blue); }
 
    /* ── CTA BANNER ── */
    .cta-banner {
      background: var(--primary-blue); padding: 60px; text-align: center;
    }
    .cta-banner h2 { font-size: 36px; font-weight: 900; color: var(--black); margin-bottom: 12px; font-family: var(--font-title); }
    .cta-banner p { font-size: 17px; color: rgba(0,0,0,.75); margin-bottom: 28px; }
 
    /* ── INFO CARDS ROW ── */
    .info-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; padding: 40px 80px; background: var(--gray-light); }
    .info-card { background: var(--white); border-radius: 16px; padding: 32px; text-align: center; border: 1px solid var(--gray-200); }
    .info-card .icon { font-size: 36px; margin-bottom: 16px; }
    .info-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; font-family: var(--font-title); }
    .info-card p { font-size: 14px; color: var(--gray-500); }
 
    /* ── PSICOLOGÍA PAGE ── */
    .hero-psico {
      background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%);
      padding: 80px; text-align: center;
    }
    .hero-psico .badge-blue {
      background: var(--primary-blue); color: var(--black);
      border-radius: 50px; padding: 6px 18px; font-size: 13px; font-weight: 600;
      display: inline-block; margin-bottom: 20px;
    }
    .hero-psico h1 { font-size: 48px; font-weight: 900; color: var(--primary-blue); margin-bottom: 16px; font-family: var(--font-title); }
    .hero-psico p { font-size: 17px; color: var(--gray-500); margin-bottom: 28px; }
    .btn-orange { background: var(--yellow); color: var(--black); padding: 14px 32px; border-radius: 50px; font-size: 16px; font-weight: 700; border: none; cursor: pointer; transition: background .2s; }
    .btn-orange:hover { background: #e6b800; }
 
    .alert-crisis {
      border: 2px solid var(--red); border-radius: 12px;
      padding: 28px 32px; margin: 0 80px 40px;
    }
    .alert-crisis h3 { color: var(--red); font-size: 18px; font-weight: 700; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
    .alert-crisis p { color: var(--gray-700); font-size: 15px; margin-bottom: 12px; }
    .alert-crisis .contact-line { font-size: 15px; margin-bottom: 6px; }
    .alert-crisis a { color: var(--primary-blue); text-decoration: none; }
    .alert-crisis .ver-mas { color: var(--primary-blue); font-size: 14px; text-decoration: none; margin-top: 10px; display: inline-block; }
 
    .psy-services { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding: 0 80px 60px; }
    .psy-card { border: 1px solid var(--gray-200); border-radius: 12px; padding: 24px; display: flex; align-items: flex-start; gap: 16px; }
    .psy-icon-box { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .psy-icon-blue { background: #eff6ff; }
    .psy-icon-green { background: #f0fdf4; }
    .psy-card h4 { font-size: 16px; font-weight: 700; color: var(--primary-blue); margin-bottom: 6px; font-family: var(--font-title); }
    .psy-card p { font-size: 14px; color: var(--gray-500); line-height: 1.6; }
 
    /* ── KIOSCOS PAGE (EmprendeSpace) ── */
    .hero-kiosko {
      background: url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1400&q=80') center/cover no-repeat;
      position: relative; min-height: 520px; display: flex; align-items: center; justify-content: center; text-align: center;
    }
    .hero-kiosko::before { content: ''; position: absolute; inset: 0; background: rgba(20,40,80,.75); }
    .hero-kiosko-content { position: relative; z-index: 2; color: var(--white); }
    .hero-kiosko-content h1 { font-size: 52px; font-weight: 900; margin-bottom: 16px; font-family: var(--font-title); }
    .hero-kiosko-content p { font-size: 18px; color: rgba(255,255,255,.8); margin-bottom: 28px; }
    .btn-kiosko {
      background: transparent; border: 2px solid var(--white);
      color: var(--white); padding: 14px 36px; border-radius: 8px;
      font-size: 16px; font-weight: 600; cursor: pointer; transition: all .2s;
    }
    .btn-kiosko:hover { background: var(--white); color: var(--blue-dark); }
 
    .kiosko-stats { display: flex; padding: 32px 80px; border-bottom: 1px solid var(--gray-200); gap: 0; }
    .kiosko-stat { flex: 1; text-align: center; }
    .kiosko-stat-num { font-size: 44px; font-weight: 900; font-family: var(--font-title); }
    .kiosko-stat-label { font-size: 14px; color: var(--gray-500); }
    .kiosko-divider { width: 1px; background: var(--yellow); opacity: .3; margin: 0 20px; }
 
    .kiosko-filters { display: flex; gap: 12px; padding: 32px 80px 16px; flex-wrap: wrap; }
    .filter-sidebar { width: 200px; flex-shrink: 0; }
    .filter-sidebar .filter-group { margin-bottom: 20px; }
    .filter-sidebar .filter-group h4 { font-size: 13px; font-weight: 600; color: var(--gray-500); margin-bottom: 10px; text-transform: uppercase; }
    .filter-btn { display: flex; align-items: center; gap: 8px; padding: 8px 12px; border-radius: 8px; font-size: 14px; cursor: pointer; width: 100%; border: none; background: transparent; color: var(--gray-700); transition: background .2s; margin-bottom: 4px; }
    .filter-btn:hover, .filter-btn.active { background: #fff7ed; color: var(--yellow); }
    .filter-btn.active { font-weight: 600; }
 
    .kioscos-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .kiosko-card { border: 1px solid var(--gray-200); border-radius: 16px; overflow: hidden; }
    .kiosko-card-img { height: 160px; object-fit: cover; width: 100%; }
    .kiosko-card-body { padding: 20px; }
    .kiosko-tag { display: inline-block; padding: 3px 12px; border-radius: 50px; font-size: 12px; font-weight: 600; margin-bottom: 8px; }
    .tag-comida { background: #fef3c7; color: #92400e; }
    .tag-papeleria { background: #dbeafe; color: #1d4ed8; }
    .tag-bebidas { background: #dcfce7; color: #15803d; }
    .kiosko-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 12px; font-family: var(--font-title); }
    .kiosko-meta { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--gray-500); margin-bottom: 4px; }
    .kiosko-products h4 { font-size: 12px; font-weight: 600; color: var(--gray-500); margin: 12px 0 6px; }
    .kiosko-products ul { list-style: none; }
    .kiosko-products li { font-size: 13px; color: var(--gray-700); padding: 2px 0; display: flex; align-items: center; gap: 6px; }
    .kiosko-products li::before { content: '•'; color: var(--yellow); font-weight: 700; }
    .kiosko-responsable { font-size: 12px; color: var(--gray-500); margin-top: 12px; border-top: 1px solid var(--gray-100); padding-top: 10px; }
 
    /* ── CLUBS PAGE ── */
    .clubs-hero {
      padding: 60px 80px; text-align: center;
      background: linear-gradient(180deg, #f0f9ff 0%, var(--white) 100%);
    }
    .club-section-title {
      font-size: 28px; font-weight: 800; margin: 0 80px 8px; display: flex; align-items: center; gap: 12px; font-family: var(--font-title);
    }
    .club-section-title::before { content: ''; display: block; width: 4px; height: 32px; background: var(--primary-blue); border-radius: 4px; }
    .clubs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; padding: 16px 80px 60px; }
    .club-card { border: 1px solid var(--gray-200); border-radius: 16px; overflow: hidden; cursor: pointer; transition: box-shadow .2s; }
    .club-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.1); }
    .club-card-img { height: 180px; object-fit: cover; width: 100%; }
    .club-card-body { padding: 20px; }
    .club-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 6px; font-family: var(--font-title); }
    .club-card p { font-size: 13px; color: var(--gray-500); margin-bottom: 12px; }
    .club-meta { display: flex; justify-content: space-between; font-size: 12px; color: var(--gray-500); }
    .btn-ver-club { display: block; text-align: center; padding: 10px; border: 1.5px solid var(--gray-200); border-radius: 8px; font-size: 14px; font-weight: 600; color: var(--gray-700); cursor: pointer; transition: all .2s; margin-top: 12px; text-decoration: none; }
    .btn-ver-club:hover { border-color: var(--primary-blue); color: var(--primary-blue); }
    .btn-unirse { display: block; text-align: center; padding: 10px; background: var(--primary-blue); border-radius: 8px; font-size: 14px; font-weight: 600; color: var(--black); cursor: pointer; margin-top: 8px; border: none; width: 100%; transition: background .2s; }
    .btn-unirse:hover { background: var(--blue-dark); }
 
    /* ── BIENESTAR PAGE ── */
    .bienestar-hero {
      background: linear-gradient(135deg, #fdf4ff 0%, #f5f3ff 100%);
      padding: 80px; text-align: center;
    }
    .bienestar-hero h1 { font-size: 44px; font-weight: 900; margin-bottom: 14px; font-family: var(--font-title); }
    .bienestar-hero p { font-size: 17px; color: var(--gray-500); }
 
    .bienestar-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; padding: 40px 80px; }
    .bienestar-card { border-radius: 16px; padding: 28px; text-align: center; }
    .bienestar-card.purple { background: #f5f3ff; }
    .bienestar-card.green { background: #f0fdf4; }
    .bienestar-card.blue { background: #eff6ff; }
    .bienestar-card .b-icon { font-size: 40px; margin-bottom: 14px; }
    .bienestar-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; font-family: var(--font-title); }
    .bienestar-card p { font-size: 14px; color: var(--gray-500); line-height: 1.6; }
 
    /* ── FOOTER ── */
    .footer {
      background: var(--blue-dark); color: var(--white);
      padding: 60px 80px 30px;
    }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 60px; margin-bottom: 40px; }
    .footer h3 { font-size: 18px; font-weight: 800; margin-bottom: 8px; font-family: var(--font-title); }
    .footer p { font-size: 14px; color: rgba(255,255,255,.6); line-height: 1.7; }
    .footer h4 { font-size: 14px; font-weight: 700; margin-bottom: 16px; }
    .footer ul { list-style: none; }
    .footer ul li { margin-bottom: 10px; }
    .footer ul li a { color: rgba(255,255,255,.6); text-decoration: none; font-size: 14px; cursor: pointer; transition: color .2s; }
    .footer ul li a:hover { color: var(--white); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.1); padding-top: 20px; text-align: center; font-size: 13px; color: rgba(255,255,255,.4); }
 
    /* ── CINE CLUB PAGE ── */
    .cine-nav {
      background: var(--blue-dark); display: flex; align-items: center;
      padding: 14px 40px; gap: 32px; position: sticky; top: 0; z-index: 100;
    }
